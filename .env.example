# Quantum MCP Relayer Configuration
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Quantum Backend
QUANTUM_BACKEND=simulator
# Options: simulator, originqc
ORIGINQC_API_KEY=
ORIGINQC_ENDPOINT=

# Rate Limiting
RATE_LIMIT_FREE=10
RATE_LIMIT_STARTER=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_BUSINESS=10000

# API Keys
API_KEY_SALT=change-this-to-random-string
